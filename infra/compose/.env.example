# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jobuler
POSTGRES_USER=jobuler
POSTGRES_PASSWORD=changeme_local

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── API ──────────────────────────────────────────────────────
API_PORT=5000
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
JWT_ISSUER=jobuler-api
JWT_AUDIENCE=jobuler-web
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ─── Solver ───────────────────────────────────────────────────
SOLVER_PORT=8000
SOLVER_TIMEOUT_SECONDS=60

# ─── Frontend ─────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── MinIO (S3-compatible local storage) ──────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── AI (optional) ────────────────────────────────────────────────────────────
# Leave empty to disable AI features — app runs fine without it
AI_API_KEY=
AI_MODEL=gpt-4o

# ─── SendGrid (Email) ──────────────────────────────────────────────────────────
# Leave empty to use no-op (logs only, no real emails sent)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@shifter.app
SENDGRID_FROM_NAME=Shifter

# ─── Twilio (WhatsApp) ────────────────────────────────────────────────────────
# Leave empty to use no-op (logs only, no real WhatsApp messages sent)
# Use the Twilio sandbox number for testing: whatsapp:+14155238886
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
